{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommitType(chore)",
    ":separatePatchReleases"
  ],
  "commitMessagePrefix": "chore(all): ",
  "commitMessageAction": "update",
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "labels": [
    "dependencies"
  ],
  "enabledManagers": [
    "gomod",
    "github-actions",
    "dockerfile",
    "mise"
  ],
  "prConcurrentLimit": 50,
  "prHourlyLimit": 0,
  "platformAutomerge": false,
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "ignoreTests": false,
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  },
  "packageRules": [
    {
      "description": "Wait 3 days before automerging major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Bump Go version in go.mod to latest patch",
      "matchManagers": [
        "gomod"
      ],
      "matchDepNames": [
        "go"
      ],
      "rangeStrategy": "bump"
    },
    {
      "description": "Group GitHub Actions into one PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions",
      "commitMessagePrefix": "chore(actions): "
    },
    {
      "description": "Group Go modules",
      "matchManagers": [
        "gomod"
      ],
      "groupName": "go-modules",
      "commitMessagePrefix": "chore(go): "
    },
    {
      "description": "Group Docker base images",
      "matchManagers": [
        "dockerfile"
      ],
      "groupName": "docker",
      "commitMessagePrefix": "chore(docker): "
    },
    {
      "description": "Group mise-managed dev tools and hold each new version for 3 days so the upstream GitHub Release artifacts that mise's aqua:/go: backends install are published before the PR opens (prevents the tag-before-publish 404 on mise install)",
      "matchManagers": [
        "mise"
      ],
      "groupName": "dev-tools",
      "commitMessagePrefix": "chore(tools): ",
      "minimumReleaseAge": "3 days"
    }
  ]
}
